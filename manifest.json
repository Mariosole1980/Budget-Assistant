{
  "name": "Budget Assistant",
  "short_name": "Budget",
  "description": "Διαχείριση οικογενειακού προϋπολογισμού. Καταγράψτε έσοδα, έξοδα και αποταμιεύσεις με πραγματικό συγχρονισμό cloud.",
  "start_url": "/index.html",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#222731",
  "theme_color": "#222731",
  "orientation": "portrait-primary",
